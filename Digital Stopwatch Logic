Import java.util.Scanner;


class Stopwatch {
   
    private long startTime;
    private long elapsedTime;
    private boolean isRunning;


    public Stopwatch() {
        this.startTime = 0;
        this.elapsedTime = 0;
        this.isRunning = false;
    }

   
    public void start() {
        if (!isRunning) {
            startTime = System.currentTimeMillis();
            isRunning = true;
            System.out.println("Stopwatch Started...");
        } else {
            System.out.println("Stopwatch is already running!");
        }
    }

    
    public void stop() {
        if (isRunning) {
            elapsedTime += (System.currentTimeMillis() - startTime);
            isRunning = false;
            System.out.println("Stopwatch Stopped.");
        } else {
            System.out.println("Stopwatch is already stopped!");
        }
    }

  
    public void reset() {
        startTime = 0;
        elapsedTime = 0;
        isRunning = false;
        System.out.println("Stopwatch Reset.");
    }

    
    public long getElapsedTime() {
        if (isRunning) {
            // Calculate current live time + previously saved time
            return (System.currentTimeMillis() - startTime) + elapsedTime;
        }
        return elapsedTime;
    }
}

/**
 * Main Class to demonstrate state changes
 */
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Stopwatch sw = new Stopwatch();
        int choice;

        System.out.println("--- Digital Stopwatch Simulation ---");
        
        do {
            System.out.println("\n1. Start  2. Stop  3. Reset  4. Check Time  5. Exit");
            System.out.print("Enter choice: ");
            choice = sc.nextInt();

            switch (choice) {
                case 1:
                    sw.start();
                    break;
                case 2:
                    sw.stop();
                    break;
                case 3:
                    sw.reset();
                    break;
                case 4:
                    long timeMs = sw.getElapsedTime();
                    System.out.println("Elapsed Time: " + timeMs + " ms (" + (timeMs / 1000.0) + " seconds)");
                    break;
                case 5:
                    System.out.println("Exiting...");
                    break;
                default:
                    System.out.println("Invalid choice!");
            }
        } while (choice != 5);

        sc.close();
    }
}
